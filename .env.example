NEO4J_PASSWORD=replace-with-a-local-password
DATA_ROOT=./data/uploads
SQLITE_URL=sqlite:///./tspw-graph.db

# Used only when no administrator account exists. Change immediately after first login.
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=Pass@word1
# Set true when the public site is served through HTTPS.
AUTH_COOKIE_SECURE=false

# API receives profile metadata only. The named secret is injected only into Worker.
# Model requests per Worker process. Start with 4 in production; use 1 for serial execution.
EXTRACTION_CONCURRENCY=1
MODEL_PROFILES_JSON=[{"id":"fixed:test","provider":"fixed","base_url":"","model":"deterministic-test","api_key_env":"","timeout_seconds":10},{"id":"openai:default","provider":"openai-compatible","base_url":"https://api.openai.com/v1","model":"gpt-4.1-mini","api_key_env":"OPENAI_API_KEY","timeout_seconds":60},{"id":"azure:gpt-4o-mini","provider":"azure-openai","base_url":"https://YOUR_RESOURCE.openai.azure.com","model":"YOUR_DEPLOYMENT_NAME","api_key_env":"AZURE_OPENAI_API_KEY","api_version":"2024-06-01","timeout_seconds":60},{"id":"azure:gpt-5.6-sol","provider":"azure-openai-responses","base_url":"https://YOUR_RESOURCE.services.ai.azure.com/openai/v1","model":"YOUR_RESPONSES_DEPLOYMENT_NAME","api_key_env":"AZURE_OPENAI_API_KEY","timeout_seconds":180,"reasoning_effort":"low","max_output_tokens":12000},{"id":"ollama:local","provider":"ollama","base_url":"http://host.docker.internal:11434","model":"qwen3:8b","api_key_env":"","timeout_seconds":120}]
# Select a profile that supports QA intent parsing: azure-openai or azure-openai-responses.
QA_MODEL_PROFILE_ID=azure:gpt-5.6-sol
OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_API_KEY=replace-with-your-azure-key
